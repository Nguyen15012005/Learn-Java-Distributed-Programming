			 }
		 }
		 parser.close();
		 return list;
		 
	 }
	 
	 public List<Question> parseQuestions(JsonParser parser) {

		    List<Question> questions = new ArrayList<>();

		    String key = "";
		    String question_id = "";
		    String text = "";
		    String correct_answer = "";

		    // 🔥 dùng List tạm
		    List<String> tempOptions = new ArrayList<>();

		    while (parser.hasNext()) {
		        Event event = parser.next();

		        switch (event) {

		            case KEY_NAME:
		                key = parser.getString();
		                break;

		            case START_OBJECT:
		                // reset dữ liệu
		                question_id = "";
		                text = "";
		                correct_answer = "";
		                tempOptions = new ArrayList<>();
		                break;

		            case VALUE_STRING:

		                if (key.equals("question_id")) {
		                    question_id = parser.getString();
		                }

		                else if (key.equals("text")) {
		                    text = parser.getString();
		                }

		                else if (key.equals("correct_answer")) {
		                    correct_answer = parser.getString();
		                }

		                // 🔥 options (array)
		                else if (key.equals("options")) {
		                    tempOptions.add(parser.getString());
		                }

		                break;

		            case END_OBJECT:
		                if (!question_id.equals("")) {

		                    // 🔥 chuyển List → String
		                    String optionsStr = String.join(", ", tempOptions);

		                    Question q = new Question();
		                    q.setQuestion_Id(question_id);
		                    q.setText(text);
		                    q.setCorrect_Answer(correct_answer);
		                    q.setOptions(optionsStr);

		                    questions.add(q);
		                }
		                break;

		            case END_ARRAY:
		                return questions;

		            default:
		                break;
		        }
		    }

		    return questions;
		}
	 
	 public void writeToFile(List<Quiz> list) throws Exception{
		 JsonArrayBuilder arrayBuilder = Json.createArrayBuilder();
		 for(Quiz q : list) {
			 JsonObject obj = Json.createObjectBuilder()
					 .add("quiz_id", q.getQuiz_id())
					 .add("name", q.getName())
					 .add("score", q.getScore())
					 .build();
			 
			 arrayBuilder.add(obj);
		 }
		 
		 JsonArray arr = arrayBuilder.build();
		 
		 PrintWriter out = new PrintWriter("data/nguyen23640731.json");
		 out.println(arr.toString());
		 out.close();
	 }
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
	 
